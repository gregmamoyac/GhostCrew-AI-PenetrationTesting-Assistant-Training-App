<!DOCTYPE html>
<html>
<head>
    <title>GhostCrew Terminal Client v3.0</title>
    <HTA:APPLICATION
        ID="GhostCrewTerminalClient"
        APPLICATIONNAME="GhostCrew Terminal Client"
        BORDER="thin"
        BORDERSTYLE="normal"
        CAPTION="yes"
        ICON="shell32.dll,23"
        MAXIMIZEBUTTON="no"
        MINIMIZEBUTTON="yes"
        SCROLL="no"
        SHOWINTASKBAR="yes"
        SINGLEINSTANCE="yes"
        SYSMENU="yes"
        VERSION="3.0"
        WINDOWSTATE="minimize"
        NAVIGABLE="no"
    />
    <style>
        body {
            font-family: 'Consolas', 'Courier New', monospace;
            background-color: #0a0a0a;
            color: #00ff41;
            padding: 8px;
            margin: 0;
            overflow: hidden;
            font-size: 11px;
        }
        .header {
            background: linear-gradient(90deg, #1a1a1a, #2a2a2a);
            color: #00ff41;
            padding: 6px 10px;
            border: 1px solid #333;
            margin-bottom: 5px;
            font-weight: bold;
            text-align: center;
            border-radius: 3px;
        }
        .log-container {
            height: 140px;
            overflow-y: auto;
            background-color: #111;
            border: 1px solid #333;
            padding: 5px;
            margin-bottom: 5px;
            font-size: 10px;
            line-height: 1.2;
        }
        .status-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 4px 8px;
            background: linear-gradient(90deg, #1a1a1a, #2a2a2a);
            border-top: 1px solid #00ff41;
            font-size: 10px;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
        }
        .connection-info {
            color: #00ff41;
        }
        .session-info {
            color: #ffaa00;
        }
        .error { color: #ff4444; }
        .success { color: #00ff41; }
        .warning { color: #ffaa00; }
        .info { color: #4488ff; }
        .command { color: #ff6600; font-weight: bold; }
        .output { color: #cccccc; }
        
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #1a1a1a;
        }
        ::-webkit-scrollbar-thumb {
            background: #00ff41;
            border-radius: 4px;
        }
    </style>
    <script>
        /*! JSON v3.3.2 | http://bestiejs.github.io/json3 | Copyright 2012-2014, Kit Cambridge | http://kit.mit-license.org */
